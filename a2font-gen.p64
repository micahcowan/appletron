--[[pod_format="raw",created="2026-06-14 04:21:41",modified="2026-06-14 09:34:00",revision=96,xstickers={}]]
-- a2font-gen   by Micah Cowan
--
-- Generate (and display) an APPLE ][ Picotron font
-- from the image below
-- (image was generated externally from a text ROM dump)
img =
--[[pod_type="image"]]unpod("b64:_MC4CNxAOwHIAcWAO8AUO8AFWABBQQQFBHgAOwK8AcdAO8AAO8H7oAKAwTlAOME5ALiBOHgIg8AcjAAJBAyEeQNMBc0AeMA5wDpANARAgVQAT4BwBIBAetAIAKgEChAAVkHIDEUD_ACBQTqYABZAAMB5QHosBQHAOID56AHBAPvADDvAD6ABgHhAOQA5QZQAjTmAlAhJQfQAFSAACkAEBsQFFDiAOUGoAAioAADIBUGAO4A7Q4gKgTjAuYA5ALkAuQMsAoC7QDoAOwA5wDiA=")

font = userdata("u8", 2048)

-- !! Generate the font data !!
font:set(0,7) -- char width
font:set(1,7) -- char width (>=128)
font:set(2,8) -- char height
-- char-specific adjustments (all -> zero)
for i=3,128 do
	font:set(3,0)
end
for cp=16,255 do
	-- convert ASCII code point, to code point within the a2
	-- font image
	local cpi = cp % 64
	if (cp % 128) >= 96 then cpi -= 32 end
	-- top-left corner of the char in image
	local ix = (cpi % 16) * 8
	local iy = (cpi // 16) * 8
	-- offset to char in font
	local f = cp * 8
	for y=0,7 do
		local b=0
		for x=0,7 do
			-- get font pixel from image
			local p = img:get(ix+x, iy+y)
			-- convert pixel to boolean true/false
			p = p ~= 0
			-- reverse the pixels in codepoints >= 128
			if cp >= 128 then p = not p end
			-- convert the pixel into most-significant bit of a byte
			if p then p = 0x80 else p = 0 end
			-- (font bits are stored in reverse)
			b = (b >> 1) | p
		end
		b >>= 1 -- shift font 1 to the left, to adjust for 7-pixel font width
		font:set(f+y, b)
	end
end

font:poke(0x5600) -- set as the alternate font
	
--set_clipboard(pod(font, 7, {pod_type="font"}))
mkdir("/appdata/shared/fonts")
local path="/appdata/shared/fonts/a2.font"
store(path, font)

function _draw()
	cls()
	hex="0123456789ABCDEF"
	-- display font starting from codepoint 16
	-- (preceding codepoints are not displayable)
	print("      \014" .. hex .. "\015        " .. "      " .. hex)
	print""
	for i=16,240,16 do
		s = ""
		for j=i, i+15 do
			s ..= chr(j)
		end
		local y=(i//16)*8
		print(hex[(i // 16)+1] .. "_    \014" .. s .. "\015        "
			.. hex[(i // 16)+1] .. "_    " .. s)
	end
	print""
	
	print("Font data has been saved to " .. path)
	print("    TRY! > fetch(\"" .. path .. "\"):poke(0x4000)")
	print""
	print"NOTE: not possible to type lowercase,"
	print"      or following punctuation: `{|}~"
	print"(type ESC to exit)"
end
