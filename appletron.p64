--[[pod_format="raw",created="2026-06-15 05:52:44",modified="2026-06-20 05:15:01",revision=62,xstickers={}]]
-- appletron   by Micah Cowan <micah@addictivecode.org>
--
-- An emulator of the Apple ][ for Picotron
-- written in Lua (with Picotron language additions)
-- https://github.com/micahcowan/appletron

--include "cpu6502.lua"
include "video.lua"
include "bus.lua"

--[[
cycles_per_frame = 17292
cycles_per_line = 65
vblank_cycles = 70 * cycles_per_line
--]]

App = {}

function App.new(class)
	app = {}
	
	-- TODO: handle missing ROM file, making sure to create /appdata dir
	local path ="/appdata/bbs/appletron/apple2plus.rom"
	if type(env().sandbox) ~= "nil" then
		path = "/appdata/apple2plus.rom"
	end
	local rom = fetch(path)
	app.bus = Bus.new{rom = rom, rom_start = 0xD000}
	app.video = Video.new(app.bus)
	
	-- public methods
	function app.update(self)
		local step = time() // (1/4.2)
		
		if self.did_thing or step <= self.did_step then
			-- nothing to do
		else
			self.did_step = step
			
			if (step < 2) return
			step -= 2
			if step < 24 then
				local base = Video.get_line_addr(1024, step)
				local c = 0xB0 + step
				if (step > 9) c = 0xC1 - 10 + step
				self.bus:poke(base, c)
			elseif step == 31 then
				self.did_thing = true
				local y = 0
				local base
				for i=0,255 do
					local x = i % 16
					if x == 0 then
						y = i // 16
						base = Video.get_line_addr(1024, y)
					end
					self.bus:poke(base + x, i)
				end
			end
		end
	end

	function app.draw(self)
		--self.video:display()
		cls()
--		print(pod(env()))
		s=""
		for loc=0xCFFF,0xD003 do
			s ..= tostr(self.bus:peek(loc), 16) .. " "
		end
		print(s, 0, 0)
		s=""
		for loc=0xFFF8,0xFFFF do
			s ..= tostr(self.bus:peek(loc), 16) .. " "
		end
		print(s, 0, 10)
		print(tostr(self.bus:peek(0xFFFF), 16), 0, 20)
	end
	
	palt(0) -- no transparent pixels
	poke(0x5f58, 0x11) -- print() uses solid background
	fetch("a2.font"):poke(0x4000)
	app.did_thing = false
	app.did_step = 0
	
	return app
end
:: bus.lua
--[[pod_format="raw",created="2026-06-15 06:12:09",modified="2026-06-20 04:56:13",revision=19,xstickers={}]]
-- bus.lua
--
-- Manages reading/writing from the emulated Apple ]['s
-- data bus (usually, memory, sometimes soft switches
-- or peripherals)

Bus = {}

function Bus.new(opts)
	local bus = {
		-- private data members
		_mem = userdata("u8", 65536),
		_poke_lsnrs = {}, -- TODO: abstract listening into its own class
		_rom_start = 65536, -- past the end of memory
	}
	for k in all{
		"rom",
		"rom_start",
	} do
		if type(opts[k]) ~= nil then
			bus["_" .. k] = opts[k]
		end
	end
	
	-- public methods
	function bus.peek(self, addr)
		-- read a value off the Apple ][ bus
		local val
		local rom, rs = self._rom, self._rom_start
		local rty = type(rom)
		if rty ~= "nil" and addr >= rs and addr - rs < #rom then
			if rty == "string" then
				-- string (fetched from file) is allowed
				val = ord(rom[1 + addr - rs])
			elseif rty == "userdata" then
				val = rom[addr - rs]
			end
		else
			val = self._mem[addr]
		end
		
		return val
	end
	
	function bus.poke(self, addr, val)
		-- write a value to the Apple ][ bus
		assert(type(val) == "number",
			"Non-numeric type given to bus:peek(): " .. pod(val))
		self._mem[addr] = val
		self:_alert_listeners(self._poke_lsnrs, addr, val)
	end
	
	function bus.listen_poke(self, handler)
		assert(type(handler) == "function",
			"bus:listen_poke: expected function arg")
		add(self._poke_lsnrs, handler)
	end
	
	-- private methods
	function bus._alert_listeners(self, listeners, addr, val)
		for handler in all(listeners) do
			handler(addr, val)
		end
	end
	
	-- clear RAM to a plausible startup pattern
	for i=0,65535 do
		local val
		if (i & 0x02) ~= 0 then
			val = 0
		else
			val = 0xFF
		end
		bus._mem[i] = val
	end
	
	-- AppleWin does the following, which improves functionality
	-- of some programs that depend, unfortunately, on
	-- certain memory locations not being cleared
	for z=0,65535,512 do
		bus._mem[z + 0x28] = flr(rnd(256))
		bus._mem[z + 0x29] = flr(rnd(256))
		bus._mem[z + 0x68] = flr(rnd(256))
		bus._mem[z + 0x69] = flr(rnd(256))
	end

	return bus
end
:: main.lua
--[[pod_format="raw",created="2026-06-13 05:26:30",modified="2026-06-19 19:02:32",revision=191,xstickers={}]]
-- appletron   by Micah Cowan <micah@addictivecode.org>
--
-- An emulator of the Apple ][ for Picotron
-- written in Lua (with Picotron language additions)
-- https://github.com/micahcowan/appletron

include "app.lua"

do
	-- local function
	local function setup_keys()
		on_event("keydown",
			function(msg)
				local c = stat(302, msg.scancode)
				if c == "F1" then
					window{pauseable = true}
					--send_message(3, {event = "set_window", attribs = {pauseable = true}}, true)
					
					-- unfortunately, the following doesn't work when sandboxed! :(
					send_message(3, {event = "toggle_pause_menu"})
					-- ...still, we just toggled pauseable to true, so they can now hit Enter
					-- afterward, I suppose. Or run us unsandboxed.
				elseif c == "Escape" then
					-- We won't want to do this forever, but XXX
				end
			end
		)
		on_event("unpause", function(msg)
			window{pauseable = false}
		end)
	end
	
	-- public functions
	function _init()
		window{
			width = 280,
			--height = 192,
			height = 192 + 16,
			resizeable = false,
			pauseable = false,
			capture_escapes = true,
		}
		setup_keys()
		
		theApp = App:new()
	end
	
	function _update()
		theApp:update()
	end
	
	function _draw()
		theApp:draw()
	end
	
end -- do
:: video.lua
--[[pod_format="raw",created="2026-06-15 06:05:43",modified="2026-06-17 14:08:51",revision=13,xstickers={}]]
-- video.lua
--
-- Video subsystem. Responsible for drawing the Apple ][ screen
-- contents.
--
-- I originally attempted something more cycle-accurate, that
-- could handle funky graphical effects achieved by messing with
-- video memory while the screen is still being drawn...
-- however, poor Picotron simply cannot handle the number of
-- cycles that required: performance toggled between 60fps,
-- and 1-2fps, just for the display system, with no actual
-- CPU emulation going on.
--
-- So I went for a highly-simplified display system, where text
-- is handled directly by Picotron's `print()` function,
-- using a bespoke font. Less accurate, but far faster, and
-- still handles the vast majority of situations (basically,
-- everything outside of clever tech demos)

Video = {}

function Video.get_line_addr(base, lnum)
	-- Get the memory address to the start of the specified
	-- line of text
	local grp = lnum // 8
	local sln = lnum % 8
	return base + ((40 * grp) | (sln << 7))
end

function Video.new(bus)
	local video = {
		-- public data members
		flashing = false,
		-- private data members
		_bus = bus,
		_dirty_info = 0,
		_base = 1024, -- base address of video memory (1024 or 2048)
	}
	
	-- public methods
	function video.display(self)
		-- is it time to update flashing characters?
		local newflash = ((time() % (2/2.1)) > 1/2.1) ~= self.flashing
		if newflash then
			self.flashing = not self.flashing -- reverse
			self:_set_dirty()
		end
		
		if newflash or self:_dirty() then
			local b = self._bus
			for i=0,23 do
				if self:_dirty(i) then
					local line=""
					local addr=self:get_line_addr(i)
					for j=0,39 do
						local c = b:peek(addr + j)
						line ..= self:_vidchar(c)
					end
					print(line, 0, i*8, 25)
				end
			end
			self:_clear_dirty()
		end
		
		local fr = stat(1)
		local cpu = stat(7)
		print(fr, 0, 24 * 8)
		print(cpu, 0, 25 * 8)
	end
	
	function video.get_line_addr(self, lnum)
		return Video.get_line_addr(self._base, lnum)
	end
	
	-- private methods
	function video._vidchar(self, c)
		-- convert an Apple ][ char to the codepoint to use
		-- in our font
		local cp = (c + 32) % 64 + 32
		if c < 64 or (c<128 and self.flashing) then cp |= 128 end
		return chr(cp)
	end
	
	function video._clear_dirty(self)
		-- declare that no lines need redrawing
		self._dirty_info = 0
	end
	
	function video._dirty(self, lnum)
		-- check if any lines need redrawing,
		-- or if lnum is given, check a specific line (0-based)
		if type(lnum) == "nil" then
			return self._dirty_info ~= 0
		else
			return lnum & (1 << lnum)
		end
	end
	
	function video._set_dirty(self, lnum)
		-- mark a line as dirty.
		-- if arg not given, mark all lines as dirty.
		if type(lnum) == "nil" then
			self._dirty_info = (1 << 40) - 1
		elseif type(lnum) == "number" then
			assert(lnum >= 0, "video:_set_dirty: lnum < 0")
			assert(lnum < 40, "video:_set_dirty: lnum >= 40: "
				.. tostr(lnum))
			self._dirty_info |= (1 << lnum)
		end
	end
	
	function video._get_lnum_for_addr(self, addr)
		local lnum = nil
		if addr < self._base or addr >= self._base + 1024
				or (addr % 128) >= 120 then
			-- leave lnum nil: not a valid text/lores location
		else
			-- group portion of address (which 3rd of screen):
			local gr  = (addr & 0x7F) // 40
			-- line number within that group:
			local sln = (addr & 0x380) >> 7
			lnum = gr * 8 + sln
		end
		return lnum
	end
	
	video:_set_dirty() -- screen needs initial draw
	
	-- listen for memory changes
	video._bus:listen_poke(function(addr, val)
		if addr >= 0x400 and addr < 0xC00 then
			local lnum = video:_get_lnum_for_addr(addr)
			if type(lnum) ~= "nil" then
				video:_set_dirty(lnum)
			end
			--[[
			print(tostr(video._dirty_info, 1) .. "  " .. tostr(lnum)
				.. "     ", 0, 26 * 8)
			--]]
		end
	end)
	return video
end
