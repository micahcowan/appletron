--[[pod_format="raw",created="2026-06-20 21:34:33",modified="2026-06-20 21:34:33",revision=0,xstickers={}]]
-- util.lua
--
-- Miscellaneous utility routines

function hex(n)
	return string.format("%02X", n)
end
:: video.lua
--[[pod_format="raw",created="2026-06-15 06:05:43",modified="2026-06-20 21:25:58",revision=28,xstickers={}]]
-- video.lua
--
-- Video subsystem. Responsible for drawing the Apple ][ screen
-- contents.
--
-- I originally attempted something more cycle-accurate, that
-- could handle funky graphical effects achieved by messing with
-- video memory while the screen is still being drawn...
-- however, poor Picotron simply cannot handle the number of
-- cycles that required: performance toggled between 60fps,
-- and 1-2fps, just for the display system, with no actual
-- CPU emulation going on.
--
-- So I went for a highly-simplified display system, where text
-- is handled directly by Picotron's `print()` function,
-- using a bespoke font. Less accurate, but far faster, and
-- still handles the vast majority of situations (basically,
-- everything outside of clever tech demos)

Video = {}

function Video.get_line_addr(base, lnum)
	-- Get the memory address to the start of the specified
	-- line of text (0-based)
	local grp = lnum // 8
	local sln = lnum % 8
	return base + ((40 * grp) | (sln << 7))
end

function Video.new(class, bus)
	local video = {
		-- public data members
		flashing = false,
		-- private data members
		_bus = bus,
		_dirty_info = 0,
		_base = Locs.TEXT1, -- base address of video memory (1024 or 2048)
		
		-- The following are NOT the Apple ]['s CH/CV (x,y pos), but are
		-- internal, for the purpose of writing internal diagnostics to
		-- display memory in the machine (used by cpu:_halt())
		_ch = 0,
		_cv = 0,
	}
	
	-- public methods
	function video:display()
		-- is it time to update flashing characters?
		local newflash = ((time() % (1/2)) >= 1/4) ~= self.flashing
		if newflash then
			self.flashing = not self.flashing -- reverse
			self:_set_dirty()
		end
		
		if newflash or self:_dirty() then
			local b = self._bus
			for i=0,23 do
				if self:_dirty(i) then
					local line=""
					local addr=self:get_line_addr(i)
					for j=0,39 do
						local c = b:peek(addr + j)
						line ..= self:_vidchar(c)
					end
					print(line, 0, i*8, 25)
				end
			end
			self:_clear_dirty()
		end
		
		local fr = stat(1)
		local cpu = stat(7)
		print(fr, 0, 24 * 8)
		print(cpu, 0, 25 * 8)
	end
	
	function video:get_line_addr(lnum)
		return Video.get_line_addr(self._base, lnum)
	end
	
	function video:cls()
		-- Set TEXT1 and clear screen to spaces
		-- set internal cursor to 0,0
		self._base = Locs.TEXT1
		self._ch = 0
		self._cv = 0
		for loc=Locs.TEXT1,(Locs.TEXT2-1) do
			self._bus:poke(loc, 0xA0 --[[space char]])
		end
	end
	
	function video:prln(msg)
		video:print(msg)
		-- now move to next line
		if self._ch ~= 0 then
			self._ch = 0
			self._cv += 1
		end
	end
	
	function video:print(msg, attrib)
		local lnbas = Video.get_line_addr(Locs.TEXT1, self._cv)
		for i=1,#msg do
			-- print a character
			local c = ord(msg[i])
			if (c >= 0x60) c -= 0x20
			c |= 0x80		-- NORMAL text display
			if type(attrib) ~= "nil" then
				c += attrib		-- apply any requested font-shift,
				c %= 0x100		-- keeping it within range
			end
			video._bus:poke(lnbas + self._ch, c)
			
			self._ch += 1
			if self._ch >= 40 then
				self._ch = 0
				self._cv += 1
				lnbas = Video.get_line_addr(Locs.TEXT1, self._cv)
			end
		end
	end
	
	-- private methods
	function video:_vidchar(c)
		-- convert an Apple ][ char to the codepoint to use
		-- in our font
		local cp = (c + 32) % 64 + 32
		if c < 64 or (c<128 and self.flashing) then cp |= 128 end
		return chr(cp)
	end
	
	function video:_clear_dirty()
		-- declare that no lines need redrawing
		self._dirty_info = 0
	end
	
	function video:_dirty(lnum)
		-- check if any lines need redrawing,
		-- or if lnum is given, check a specific line (0-based)
		if type(lnum) == "nil" then
			return self._dirty_info ~= 0
		else
			return lnum & (1 << lnum)
		end
	end
	
	function video:_set_dirty(lnum)
		-- mark a line as dirty.
		-- if arg not given, mark all lines as dirty.
		if type(lnum) == "nil" then
			self._dirty_info = (1 << 40) - 1
		elseif type(lnum) == "number" then
			assert(lnum >= 0, "video:_set_dirty: lnum < 0")
			assert(lnum < 40, "video:_set_dirty: lnum >= 40: "
				.. tostr(lnum))
			self._dirty_info |= (1 << lnum)
		end
	end
	
	function video:_get_lnum_for_addr(addr)
		local lnum = nil
		if addr < self._base or addr >= self._base + Locs.LORES_SZ
				or (addr % 128) >= 120 then
			-- leave lnum nil: not a valid text/lores location
		else
			-- group portion of address (which 3rd of screen):
			local gr  = (addr & 0x7F) // 40
			-- line number within that group:
			local sln = (addr & 0x380) >> 7
			lnum = gr * 8 + sln
		end
		return lnum
	end
	
	video:_set_dirty() -- screen needs initial draw
	
	-- listen for memory changes
	video._bus:listen_poke(function(addr, val)
		if addr >= Locs.TEXT1 and addr < (Locs.TEXT2 + Locs.LORES_SZ) then
			local lnum = video:_get_lnum_for_addr(addr)
			if type(lnum) ~= "nil" then
				video:_set_dirty(lnum)
			end
			--[[
			print(tostr(video._dirty_info, 1) .. "  " .. tostr(lnum)
				.. "     ", 0, 26 * 8)
			--]]
		end
	end)
	return video
end
