--[[pod_format="raw",created="2026-06-20 20:37:32",modified="2026-06-20 20:41:40",revision=2,xstickers={}]]
-- a2locs.lua
--
-- Important memory locations on the Apple ][

Locs = {
	TEXT1		= 0x400,		-- lores and text screen
	TEXT2		= 0x800,		-- alternate lores/text screen
	LORES_SZ	= 1024,		-- size of a lorez/text screen
	
	-- Locations for important in-memory CPU jump addresses
	Vec = {
		NMI	= 0xFFFA,
		RESET	= 0xFFFC,
		IRQ		= 0xFFFE,
		BRK	= 0xFFFE, -- same as IRQ
	},
}
:: app.lua
--[[pod_format="raw",created="2026-06-15 05:52:44",modified="2026-06-21 17:13:02",revision=116,xstickers={}]]
-- appletron   by Micah Cowan <micah@addictivecode.org>
--
-- An emulator of the Apple ][ for Picotron
-- written in Lua (with Picotron language additions)
-- https://github.com/micahcowan/appletron

include "cpu6502.lua"
include "video.lua"
include "bus.lua"

--[[
cycles_per_frame = 17292
cycles_per_line = 65
vblank_cycles = 70 * cycles_per_line
--]]

App = {}

function App.new(class, opts)
	app = {}
	if type(opts) == "nil" then
		opts = {
			mode = "optest",
		}
	end
	app._opts = opts
	
	if opts.mode == "normal" then
		-- TODO: handle missing ROM file, making sure to create /appdata dir
		local path ="/appdata/bbs/appletron/apple2plus.rom"
		if type(env().sandbox) ~= "nil" then
			path = "/appdata/apple2plus.rom"
		end
		local rom = fetch(path)
		app.bus = Bus:new{rom = rom, rom_start = 0xD000}
	elseif opts.mode == "optest" then
		local ramfile = fetch("ftest6502.pod")
		if type(ramfile) == "nil" then
			error("Mode is optest, can't find ./ftest6502.pod")
		end
		app.bus = Bus:new()
		app.bus._mem = unpod(ramfile) -- replace ram with loaded tests
--		app.bus._mem[1] = 0xCD
--		local rst = Locs.Vec.RESET
--		app.bus._mem[rst] = 0x01
--		app.bus._mem[rst+1] = 0x00
	else
		error("Unknown opts.mode \"" .. opts.mode .. "\"")
	end
	app.video = Video:new(app.bus)
	app.cpu = Cpu6502:new(app.bus)
	app.cpu._video = app.video -- for cpu:_illop()
	if (opts.mode == "optest") app.cpu.testmode = true
	
	-- public methods
	if true then -- don't run display test
	function app:update()
		app.cpu:run(17030)
	end
	else -- true: run display test mode
	function app:update()
		local step = time() // (1/4.2)
		
		if self.did_thing or step <= self.did_step then
			-- nothing to do
		else
			self.did_step = step
			
			if (step < 2) return
			step -= 2
			if step < 24 then
				local base = Video.get_line_addr(1024, step)
				local c = 0xB0 + step
				if (step > 9) c = 0xC1 - 10 + step
				self.bus:poke(base, c)
			elseif step == 31 then
				self.did_thing = true
				local y = 0
				local base
				for i=0,255 do
					local x = i % 16
					if x == 0 then
						y = i // 16
						base = Video.get_line_addr(1024, y)
					end
					self.bus:poke(base + x, i)
				end
			end
		end
	end
	end -- display test mode?

	function app:draw()
		self.video:display()
	end
	
	palt(0) -- no transparent pixels
	poke(0x5f58, 0x11) -- print() uses solid background
	fetch("a2.font"):poke(0x4000)
	app.did_thing = false
	app.did_step = 0
	
	return app
end
:: bus.lua
--[[pod_format="raw",created="2026-06-15 06:12:09",modified="2026-06-20 22:17:59",revision=27,xstickers={}]]
-- bus.lua
--
-- Manages reading/writing from the emulated Apple ]['s
-- data bus (usually, memory, sometimes soft switches
-- or peripherals)

Bus = {}

function Bus.new(class, opts)
	local bus = {
		-- private data members
		_mem = userdata("u8", 65536),
		_poke_lsnrs = {}, -- TODO: abstract listening into its own class
		_rom_start = 65536, -- past the end of memory
	}
	if (type(opts) == "nil") opts = {}
	for k in all{
		"rom",
		"rom_start",
	} do
		if type(opts[k]) ~= nil then
			bus["_" .. k] = opts[k]
		end
	end
	
	-- public methods
	function bus:peek(addr)
		-- read a value off the Apple ][ bus
		local val
		local rom, rs = self._rom, self._rom_start
		local rty = type(rom)
		if rty ~= "nil" and addr >= rs and addr - rs < #rom then
			if rty == "string" then
				-- string (fetched from file) is allowed
				val = ord(rom[1 + addr - rs])
			elseif rty == "userdata" then
				val = rom[addr - rs]
			end
		else
			val = self._mem[addr]
		end
		
		return val
	end
	
	function bus:peekw(addr)
		-- peek word at addr
		local lo = self:peek(addr)
		local hi = self:peek(addr+1)
		return lo | (hi << 8)
	end
	
	function bus:poke(addr, val)
		-- write a value to the Apple ][ bus
		assert(type(val) == "number",
			"Non-numeric type given to bus:peek(): " .. pod(val))
		self._mem[addr] = val
		self:_alert_listeners(self._poke_lsnrs, addr, val)
	end
	
	function bus:listen_poke(handler)
		assert(type(handler) == "function",
			"bus:listen_poke: expected function arg")
		add(self._poke_lsnrs, handler)
	end
	
	-- private methods
	function bus:_alert_listeners(listeners, addr, val)
		for handler in all(listeners) do
			handler(addr, val)
		end
	end
	
	-- clear RAM to a plausible startup pattern
	for i=0,65535 do
		local val
		if (i & 0x02) ~= 0 then
			val = 0
		else
			val = 0xFF
		end
		bus._mem[i] = val
	end
	
	-- AppleWin does the following, which improves functionality
	-- of some programs that depend, unfortunately, on
	-- certain memory locations not being cleared
	for z=0,65535,512 do
		bus._mem[z + 0x28] = flr(rnd(256))
		bus._mem[z + 0x29] = flr(rnd(256))
		bus._mem[z + 0x68] = flr(rnd(256))
		bus._mem[z + 0x69] = flr(rnd(256))
	end

	return bus
end
:: cpu6502.lua
--[[pod_format="raw",created="2026-06-20 05:20:44",modified="2026-06-22 05:44:54",revision=78,xstickers={}]]
-- cpu6502.lua
--
-- CPU emulation. Opcode handling is in op6502.lua
-- Also the Registers class (base class for CPU)

Registers = {}

Cpu6502 = {
	-- Processor flags
	PF = {
		C = 1,	-- carry
		Z = 2,	-- zero
		I = 4,		-- interrupts
		D = 8,	-- decimal
		B = 16,	-- break (NOT a real CPU flag, always set on PLP)
		U = 32,	-- unused (NOT a real CPU flag, always set on PLP)
		V = 64,	-- oVerflow
		N = 128,	-- negative
	},
}

include "op6502.lua"

-- NON-METHOD utility functions (Registers)
function Registers.clone(reg)
	-- clone registers from |reg|.
	-- If |reg| is a Cpu6502 instance, clone will
	-- still be _only_ a Registers instance
	local newReg = Registers:new()
	
	local cpyFlds = {
		"pc", "sp", "p", "a", "x", "y",
		"pget", "pgetd", "pput",
	}
	for f in all(cpyFlds) do
		newReg[f] = reg[f]
	end
end

-- NON-METHOD utility functions (CPU)
function Cpu6502.wd(lo, hi)
	return (lo & 0xFF) | ((hi & 0xFF) << 8)
end

function Registers.new(class)
	local Cpu = Cpu6502
	local reg = {
		-- public data members
		pc = 0,
		sp = 0,
		p = 0, -- processor flags
		a = 0, -- acc
		x = 0,
		y = 0,
	}
	
	function reg:pget(fnm)
		-- return named flag's value as boolean
		if (self.p & Cpu.PF[fnm]) ~= 0 then
			return true
		else
			return false
		end
	end
	
	function reg:pgetd(fnm)
		-- return named flag's value as 0 or 1
		if (self.p & Cpu.PF[fnm]) ~= 0 then
			return 1
		else
			return 0
		end
	end
	
	function reg:pput(fnm, val)
		-- set named flag's value (val is boolean)
		if val then
			-- set the flag
			self.p |= Cpu.PF[fnm]
		else
			-- reset the flag
			self.p &= (0xFF ~ Cpu.PF[fnm])
		end
	end
	
	return reg
end

function Cpu6502.new(class, bus)
	-- simpler mnemonics, copied from Cpu6502
	local Cpu = Cpu6502
	local PF = Cpu6502.PF

	local cpu = Registers:new() -- Cpu6502 inherits from Registers
	cpu.cycles = 0	-- approximate number of cycles
						-- remaining before we'll return control
	cpu.instrs = 0	-- # instructions executed (or attempted)
						-- since CPU start
	cpu.halted = false
	cpu._bus = bus
	
	-- public methods
	function cpu:reset()
		-- don't go through the rigamorale of cycle-by-cycle
		-- operations... Picotron doesn't afford us enough
		-- cycles to spin ourselves uselessly
		self.p |= PF.B | PF.U
		
		self:_spadv(-3)
		
		self.pc = self._bus:peekw(Locs.Vec.RESET)
		self.cycles -= 8
	end
	
	function cpu:run(cycles)
		if (self._halted) return
		local v = self._video
		self.cycles = cycles
		while self.cycles > 0 do
			if not cpu.testmode then
				self:step()
			elseif self.pc == 2 then
				-- test suite reporting success!
				self:halt()
				v:cls()
				v:prln("test suite success!")
			elseif self.pc == 1 then
				-- test suite reporting failure!
				self:halt()
				v:cls()
				v:prln("test suite FAILURE!")
				v:prln("Instr #" .. tostr(self.instrs))
				v:prln("TEST SET #" .. tostr(self._bus:peek(0x200)))
			else
				self:step()
			end
		end
	end
	
	function cpu:step()
		self.instrs += 1
		local bus = self._bus
		local op = bus:peek(self.pc)
		local pc = self.pc
		self.pc += 1 -- always advance at least 1, after an op
		self.cycles -= 1 -- always spend at least 1 cycle reading the op
		local imm = bus:peek(self.pc)
		
		local handlr = OpCodes6502[op]
		if (type(handlr) ~= "nil") then
			sf, err = pcall(function() handlr(self, op, imm) end)
			if not sf then
				error("Exception while processing op " .. hex(op)
					.. " " .. hex(imm) .. ":\n" .. err)
			end
			assert(self.a ~= nil, string.format(
				"A is nil. PC = %04X, OP = %02X %02X",
				pc, op, imm))
		else
			self.pc -= 1 -- return to where we found opcode
			self:_illop(op)
		end
	end
	
	function cpu:halt()
		self._halted = true
		self.cycles = 0
	end
	
	function cpu:push(val)
		local addr = 0x0100 + self.sp
		self._bus:poke(addr, val)
		self.sp = (self.sp - 1) % 256
	end
	
	function cpu:pop()
		local addr = 0x0100 + self.sp
		self.sp = (self.sp + 1) % 256
		return self._bus:peek(addr)
	end
	
	-- private methods
	function cpu:_spadv(n)
		-- advance stack pointer by n (can be negative), keeping
		-- it in the range 0x00 - 0xFF.
		self.sp = (self.sp + n) % 256
	end
	
	function cpu:_fxflgs(val)
		-- fixup the Zero and Negative processor flags, based on |val|.
		local nf = 0
		local Z, N = PF.Z, PF.N
		
		if (val == 0) nf |= Z
		if (val & 0x80 ~= 0) nf |= N
		-- mask out current Z, N
		cpu.p &= 0xFF ~ (Z | N)
		-- add in new flag vals
		cpu.p |= nf
	end
	
	function cpu:_illop(op)
		-- Used when illegal instruction encountered. Halt execution,
		-- and display info about the situation.
		self:halt()
		local vid = self._video
		
		-- Must grab all memory values BEFORE displaying
		-- (We may overwrite them!)
		local ctxt = "ctxt:"
		for i=self.pc,self.pc+4 do
			ctxt ..= " " .. hex(self._bus:peek(i))
		end
		local rst = hex(self._bus:peekw(Locs.Vec.RESET))
		
		vid:cls()
		vid:prln("illegal opcode encountered")
		vid:prln("opcode: " .. hex(op))
		vid:prln("pc = " .. hexwd(self.pc))
		vid:prln("instr #" .. tostr(self.instrs))
		vid:prln""
		vid:prln(ctxt)
	end
	
	function cpu:_get_immed()
		-- get byte at PC, and advance
		local val = self._bus:peek(self.pc)
		self.pc += 1
		return val
	end
	
	cpu:reset()
	return cpu
end
:: main.lua
--[[pod_format="raw",created="2026-06-13 05:26:30",modified="2026-06-20 21:33:54",revision=195,xstickers={}]]
-- appletron   by Micah Cowan <micah@addictivecode.org>
--
-- An emulator of the Apple ][ for Picotron
-- written in Lua (with Picotron language additions)
-- https://github.com/micahcowan/appletron

include "app.lua"
include "a2locs.lua"
include "util.lua"

do
	-- local function
	local function setup_keys()
		on_event("keydown",
			function(msg)
				local c = stat(302, msg.scancode)
				if c == "F1" then
					window{pauseable = true}
					--send_message(3, {event = "set_window", attribs = {pauseable = true}}, true)
					
					-- unfortunately, the following doesn't work when sandboxed! :(
					send_message(3, {event = "toggle_pause_menu"})
					-- ...still, we just toggled pauseable to true, so they can now hit Enter
					-- afterward, I suppose. Or run us unsandboxed.
				elseif c == "Escape" then
					-- We won't want to do this forever, but XXX
				end
			end
		)
		on_event("unpause", function(msg)
			window{pauseable = false}
		end)
	end
	
	-- public functions
	function _init()
		window{
			width = 280,
			--height = 192,
			height = 192 + 16,
			resizeable = false,
			pauseable = false,
			--capture_escapes = true,
		}
		setup_keys()
		
		theApp = App:new()
	end
	
	function _update()
		theApp:update()
	end
	
	function _draw()
		theApp:draw()
	end
	
end -- do
:: op6502.lua
--[[pod_format="raw",created="2026-06-20 08:38:53",modified="2026-06-22 05:33:14",revision=165,xstickers={}]]
-- op6502.lua
--
-- Op-code handling for CPU

do
	local C = Cpu6502 -- shorthand alias
	
	-- common behavior functions
	-- 	routines to handle common behaviors like add/subtract
	local function do_adc(c, val)
		if c:pget("D") then
			-- decimal-mode adc
			local sumL = (c.a & 0x0F) + (val & 0x0F) + c:pgetd("C")
			
			local crr = 0
			if (sumL > 9) crr = 1
			local sumH = (c.a >> 4) + (val >> 4) + crr
			if (sumL > 9) sumL += 6
			
			c:pput("Z", ((c.a + val + c:pgetd("C")) & 0xFF) == 0)
			c:pput("N", (subH & 0x08) != 0)
			c:pput("V", ((((sumH << 4) ~ cpu.a) & 0x80) ~= 0)
								and (((acc ^ val) & 0x80) == 0))
			if (sumH > 9) sumH += 6
			c:pput("C", sumH > 9)
			c.a = ((sumH << 4) | (sumL & 0x0F)) & 0xFF
		else
			-- binary-mode adc
			local sum = c.a + val + c:pgetd("C")
			local losum = sum & 0xFF
			c:pput("N", (sum & 0x80) ~= 0)
			c:pput("V", ((0x80 & c.a) == (0x80 & val)) and ((0x80 & c.a) ~= (0x80 & sum)))
			c:pput("Z", losum == 0)
			c:pput("C", (sum & 0x100) ~= 0)
			c.a = losum
		end
	end

	local function do_sbc_seq3(r, val)
		local diffL = (r.a & 0x0F) - (val & 0x0F) - (1 - r:pgetd("C"))
		diffL %= 256
		if (diffL & 0x10) diffL -= 6
		local diffH = (r.a >> 4) - (val >> 4) - ((diffL & 0x80) >> 7)
		diffH %= 256
		if (diffH & 0x10) diffH -= 6
		
		r.a = (((diffH << 4) | (diffL & 0x0F)) & 0xFF)
	end
	
	local function do_sbc_bin(r, val)
		local diff = r.a - val - (1 - r:pgetd("C"))
		diff %= 65536
		r:pput("N", (diff & 0x80) ~= 0)
		local v = ((0x80 & r.a) ~= (0x80 & val)) and ((0x80 & r.a) ~= (0x80 & diff))
		r:pput("V", v)
		r:pput("Z", (diff & 0xFF) == 0)
		local borrow = (r.a < val) or (r.a == val and not r:pget("C"))
		r:pput("C", not borrow)
		r.a = diff & 0xFF
	end

	local function do_sbc(c, val)
		if c:ptest("D") then
			-- decimal subtract mode
			
			-- 6502 BCD SBC implementation based on
			-- http://www.6502.org/tutorials/decimal_mode.html
			local decReg = Registers.clone(c)
			do_sbc_seq3(decReg, val)
			
			local binReg = Registers.clone(c)
			do_sbc_bin(binReg, val)
			
			c.a = decReg.a
			c.p = binReg.p
		else
			-- binary subtract mode
			do_sbc_bin(c, val)
		end
	end
	
	local function do_cmp(c, a, b)
		local diff = (a - b) % 256
		c:pput("N", (diff & 0x80) ~= 0)
		c:pput("Z", diff == 0)
		c:pput("C", a >= b)
	end
	
	local function do_bit(c, val)
		local band = c.a & val
		c:pput("N", (val & 0x80) ~= 0)
		c:pput("V", (val & 0x40) ~= 0)
		c:pput("Z", band == 0)
	end
	
	local function do_asl(cpu, val)
		cpu:pput("C", (val & 0x80) ~= 0)
		local ret = (val << 1) & 0xFF
		cpu:_fxflgs(ret)
		return ret
	end
	
	local function do_rol(cpu, val)
		local c = cpu:pgetd("C")
		cpu:pput("C", (val & 0x80) ~= 0)
		local ret = ((val << 1) & 0xFF) | c
		cpu:_fxflgs(ret)
		return ret
	end
	
	local function do_lsr(cpu, val)
		cpu:pput("C", (val & 0x01) ~= 0)
		local ret = val >> 1
		cpu:_fxflgs(ret)
		return ret
	end
	
	local function do_ror(cpu, val)
		local c = cpu:pgetd("C")
		cpu:pput("C", (val & 0x01) ~= 0)
		local ret = (val >> 1) | (c << 7)
		cpu:_fxflgs(ret)
		return ret
	end
	
	local function do_jsr(cpu, _, imm)
		cpu.pc += 1
		cpu:push(cpu.pc >> 8)		-- HI
		cpu:push(cpu.pc & 0xFF)	-- LO
		cpu.pc = C.wd(imm, cpu._bus:peek(cpu.pc))
		cpu.cycles -= 5
	end
	
	-- opcode-handler factories.
	--
	-- A lot of 6502 operations have shared behavior with other ops.
	-- We provide factory functions that create a handler that does the
	-- shared behavior; we pass in the unique behavior as a fn arg
	local function mkop_read_indx(behav)
		-- OP (MEM,x)
		return function(cpu, _, imm)
			cpu.pc += 1
			local bus = cpu._bus
			bus:peek(cpu.x)
			local addr = imm + cpu.x
			local lo = bus:peek(addr & 0xFF)
			local hi = bus:peek((addr + 1) & 0xFF)
			local val = bus:peek(lo | (hi << 8))
			behav(cpu, val)
			cpu.cycles -= 5
		end
	end
	
	local function mkop_read_imm(behav)
		-- OP #IMM
		return function(cpu, _, imm)
			cpu.pc += 1
			behav(cpu, imm)
			cpu.cycles -= 1
		end
	end
	
	local function mkop_write_abs(reg)
		return function(cpu, _, imm)
			cpu.pc += 1
			local imm2 = cpu:_get_immed()
			cpu._bus:poke(C.wd(imm, imm2), cpu[reg])
			cpu.cycles -= 3
		end
	end
	
	local function mkop_branch(flagnm, cond)
		return function(cpu, _, imm)
			cpu.pc += 1
			cpu.cycles -= 1
			local orig = cpu.pc
			local offset = cpu._bus:peek(cpu.pc)
			-- Does the named flag match the set/unset condition?
			-- (true == set)
			if ((cpu.p & C.PF[flagnm]) ~= 0) == cond then
				local offset = imm
				if (offset > 0x80) offset |= 0xFF00
				local addr = (cpu.pc + offset) % 65536
				local fake = C.wd((addr & 0xFF), (cpu.pc & 0xFF00) >> 8)
				cpu._bus:peek(fake) -- register the memory access
				if fake != addr then
					cpu.cycles -= 1
					cpu._bus:peek(addr)
				end
				cpu.pc = addr
				cpu.cycles -= 1
			else
				cpu.cycles -= 1
			end
		end
	end
	
	local function mkop_read_abs(behav)
		return function(cpu, _, imm)
			cpu.pc += 1
			local imm2 = cpu:_get_immed()
			local val = cpu._bus:peek(C.wd(imm, imm2))
			behav(cpu, val)
			cpu.cycles -= 3
		end
	end
	
	local function mkop_read_zp(behav)
		return function(cpu, _, imm)
			cpu.pc += 1
			local val = cpu._bus:peek(imm)
			behav(cpu, val)
			cpu.cycles -= 2
		end
	end
	
	local function mkop_rmw_zp(behav)
		return function(cpu, _, imm)
			cpu.pc += 1
			local val = cpu._bus:peek(imm)
			-- early poke of the value happens here IRL;
			-- since this is ZP it can't actually impact anything
			-- so we'll leave it out
			val = behav(cpu, val)
			cpu._bus:poke(imm, val)
			cpu.cycles -= 4
		end
	end

	-- (global)
	OpCodes6502 = {
		[0x01]	-- ORA (MEM,x)
			= mkop_read_indx(function(c, val) c.a |= val c:_fxflgs(c.a) end),
		[0x05]	-- ORA ZP
			= mkop_read_zp(function(c, val) c.a |= val c._fxflgs(c.a) end),
		[0x06]	-- ASL ZP
			= mkop_rmw_zp(do_asl),
		[0x08]	-- PHP
			=	function(c)
					local f = c.p
					f |= C.PF.B | C.PF.U
					c:push(f)
					c.cycles -= 2
				end,
		[0x09]	-- ORA #IMM
			= mkop_read_imm(function(c, val) c.a |= val c:_fxflgs(c.a) end),
		[0x0A]	-- ASL
			= function(c) c.a = do_asl(c, c.a) c.cycles -= 1 end,
		[0x0D]	-- ORA ABS
			= mkop_read_abs(function(c, val) c.a |= val c:_fxflgs(c.a) end),
		[0x10]	-- BPL
			= mkop_branch("N", false),
		[0x18]	-- CLC
			= function(c) c.p &= (0xFF ~ C.PF.C) c.cycles -= 1 end,
		[0x1A]	-- UNDOCUMENTED nop. ProDOS uses it to distinguish CPU types
			= function(c) c.cycles -= 1 end,
		[0x20]	-- JSR
			= do_jsr,
		[0x21]	-- AND (MEM,x)
			= mkop_read_indx(function(c, val) c.a &= val c:_fxflgs(c.a) end),
		[0x24]	-- BIT ZP
			= mkop_read_zp(do_bit),
		[0x25]	-- AND ZP
			= mkop_read_zp(function(c, val) c.a &= val c._fxflags(c.a) end),
		[0x26]	-- ROL ZP
			= mkop_rmw_zp(do_rol),
		[0x28]	-- PLP
			=	function(c)
					c.p = c:pop() | C.PF.U | C.PF.B
					c.cycles -= 3
				end,
		[0x29]	-- AND #IMM
			= mkop_read_imm(function(c, val) c.a &= val c:_fxflgs(c.a) end),
		[0x2A]	-- ROL
			= function(c) c.a = do_rol(c, c.a) c.cycles -= 1 end,
		[0x2C]	-- BIT ABS
			= mkop_read_abs(do_bit),
		[0x2D]	-- AND ABS
			= mkop_read_abs(function(c, val) c.a &= val c:_fxflgs(c.a) end),
		[0x30]	-- BMI
			= mkop_branch("N", true),
		[0x38]	-- SEC
			= function(c) c.p |= C.PF.C c.cycles -= 1 end,
		[0x3A]	-- undocumented nop
			= function(c) c.cycles -= 1 end,
		[0x41]	-- EOR (MEM,x)
			= mkop_read_indx(function(c, val) c.a = c.a ~ val c:_fxflgs(c.a) end),
		[0x45]	-- EOR ZP
			= mkop_read_zp(function(c, val) c.a = c.a ~ val c._fxflags(c.a) end),
		[0x46]	-- LSR ZP
			= mkop_rmw_zp(do_lsr),
		[0x48]	-- PHA
			=	function(c) c:push(c.a) c.cycles -= 2 end,
		[0x49]	-- EOR #IMM
			= mkop_read_imm(function(c, val) c.a = (c.a ~ val) c:_fxflgs(c.a) end),
		[0x4A]	-- LSR
			= function(c) c.a = do_lsr(c, c.a) c.cycles -= 1 end,
		[0x4C]	-- JMP
			=	function(c, _, imm, imm2)
					c.pc += 1
					local imm2 = c:_get_immed()
					c.pc = C.wd(imm, imm2)
					c.cycles -= 2
				end,
		[0x4D]	-- EOR ABS
			= mkop_read_abs(function(c, val) c.a = c.a ~ val c:_fxflgs(c.a) end),
		[0x50]	-- BVC
			= mkop_branch("V", false),
		[0x58]	-- CLI
			= function(c) c.p &= (0xFF ~ C.PF.I) c.cycles -= 1 end,
		[0x61]	-- ADC (MEM,x)
			= mkop_read_indx(do_adc),
		[0x65]	-- ADC ZP
			= mkop_read_zp(do_adc),
		[0x66]	-- ROR ZP
			= mkop_rmw_zp(do_ror),
		[0x68]	-- PLA
			=	function(c) c.a = c:pop() c.cycles -= 3 end,
		[0x69] -- ADC #IMM
			= mkop_read_imm(do_adc),
		[0x6A]	-- ROR
			= function(c) c.a = do_ror(c, c.a) c.cycles -= 1 end,
		[0x6D]	-- ADC ABS
			= mkop_read_abs(do_adc),
		[0x70]	-- BVS
			= mkop_branch("V", true),
		[0x78]	-- SEI
			= function(c) c.p |= C.PF.I c.cycles -= 1 end,
		[0x88]	-- DEY
			=	function(c)
					c.y = (c.y - 1) % 256
					c:_fxflgs(c.y)
					c.cycles -= 1
				end,
		[0x8A]	-- TXA
			= function(c) c.a = c.x c:_fxflgs(c.y) c.cycles -= 1 end,
		[0x8C]	-- STY ABS
			= mkop_write_abs("y"),
		[0x8D]	-- STA ABS
			= mkop_write_abs("a"),
		[0x8E]	-- STX ABS
			= mkop_write_abs("x"),
		[0x90]	-- BCC
			= mkop_branch("C", false),
		[0x98]	-- TYA
			= function(c) c.a = c.y c:_fxflgs(c.a) c.cycles -= 1 end,
		[0x9A]	-- TXS
			= function(c) c.sp = c.x --[[ no flag changes! ]] c.cycles -= 1 end,
		[0xA0]	-- LDY #IMM
			= mkop_read_imm(function(c, val) c.y = val c:_fxflgs(c.y) end),
		[0xA1]	-- LDA (MEM,x)
			= mkop_read_indx(function(c, val) c.a = val c:_fxflgs(c.a) end),
		[0xA2]	-- LDX #IMM
			= mkop_read_imm(function(c, val) c.x = val c:_fxflgs(val) end),
		[0xA4]	-- LDY ZP
			= mkop_read_zp(function(c, val) c.y = val c._fxflags(c.y) end),
		[0xA5]	-- LDA ZP
			= mkop_read_zp(function(c, val) c.a = val c._fxflags(c.a) end),
		[0xA6]	-- LDX ZP
			= mkop_read_zp(function(c, val) c.x = val c._fxflags(c.x) end),
		[0xA8]	-- TAY
			= function(c) c.y = c.a c:_fxflgs(c.y) c.cycles -= 1 end,
		[0xA9]	-- LDA #IMM
			= mkop_read_imm(function(c, val) c.a = val c:_fxflgs(c.a) end),
		[0xAA]	-- TAX
			= function(c) c.x = c.a c:_fxflgs(c.x) c.cycles -= 1 end,
		[0xAC]	-- LDY ABS
			= mkop_read_abs(function(c, val) c.y = val c:_fxflgs(c.y) end),
		[0xAD]	-- LDA ABS
			= mkop_read_abs(function(c, val) c.a = val c:_fxflgs(c.a) end),
		[0xAE]
			= mkop_read_abs(function(c, val) c.x = val c:_fxflgs(c.x) end),
		[0xB0]	-- BCS
			= mkop_branch("C", true),
		[0xB8]	-- CLV
			= function(c) c.p &= (0xFF ~ C.PF.V) c.cycles -= 1 end,
		[0xBA]	-- TSX
			= function(c) c.x = c.sp c:_fxflgs(c.x) c.cycles -= 1 end,
		[0xC0] -- CPY #IMM
			= mkop_read_imm(function(c, val) do_cmp(c, c.y, val) end),
		[0xC1]	-- CMP (MEM,x)
			= mkop_read_indx(function (c, val) do_cmp(c, c.a, val) end),
		[0xC2]	-- UNDOCUMENTED: NOP #IMM
			-- Used in BITSY.BOOT. Perhaps to distinguish a 65816?
			= mkop_read_imm(function() end),
		[0xC4]	-- CPY ZP
			= mkop_read_zp(function(c, val) do_cmp(c, c.y, val) end),
		[0xC5]	-- CMP ZP
			= mkop_read_zp(function(c, val) do_cmp(c, c.a, val) end),
		[0xC6]	-- DEC ZP
			=	mkop_rmw_zp(function(cpu, val)
					local ret = (val-1) % 256
					cpu:_fxflgs(r)
					return ret
				end),
		[0xC8]	-- INY
			=	function(cpu)
					cpu.y = (cpu.y + 1) % 256
					cpu:_fxflgs(cpu.y)
					cpu.cycles -= 1
				end,
		[0xC9] -- CMP #IMM
			= mkop_read_imm(function(c, val) do_cmp(c, c.a, val) end),
		[0xCA]	-- DEX
			=	function(cpu)
					cpu.x = (cpu.x - 1) % 256
					cpu:_fxflgs(cpu.x)
					cpu.cycles -= 1
				end,
		[0xCC]	-- CPY ABS
			= mkop_read_abs(function(c, val) do_cmp(c, c.y, val) end),
		[0xCD]	-- CMP ABS
			= mkop_read_abs(function(c, val) do_cmp(c, c.a, val) end),
		[0xD0]	-- BNE
			= mkop_branch("Z", false),
		[0xD8]	-- CLD
			= function(c) c.p &= (0xFF ~ C.PF.D) c.cycles -= 1 end,
		[0xE0] -- CPX #IMM
			= mkop_read_imm(function(c, val) do_cmp(c, c.x, val) end),
		[0xE1]	-- SBC (MEM,x)
			= mkop_read_indx(do_sbc),
		[0xE4]	-- CPX ZP
			= mkop_read_zp(function(c, val) do_cmp(c, c.x, val) end),
		[0xE5]	-- SBC ZP
			= mkop_read_zp(do_sbc),
		[0xE6]	-- INC ZP
			=	mkop_rmw_zp(function(cpu, val)
					local ret = (val+1) % 256
					cpu:_fxflgs(r)
					return ret
				end),
		[0xE8]	-- INX
			=	function(cpu)
					cpu.x = (cpu.x + 1) % 256
					cpu:_fxflgs(cpu.x)
					cpu.cycles -= 1
				end,
		[0xE9] -- SBC #IMM
			= mkop_read_imm(do_sbc),
		[0xEA]	-- NOP (official one)
			= function(c) c.cycles -= 1 end,
		[0xEC]	-- CPX ABS
			= mkop_read_abs(function(c, val) do_cmp(c, c.x, val) end),
		[0xED]	-- SBC ABS
			= mkop_read_abs(do_sbc),
		[0xF0]	-- BEQ
			= mkop_branch("Z", true),
		[0xF8]	-- SED
			= function(c) c.p |= C.PF.D c.cycles -= 1 end,
		
	}
	function fake() end
--[==[

        case 0x0E: // ASL, abs
            OP_RMW_ABS(val = do_asl(val));
            break;
        case 0x11: // ORA, (MEM),y
            OP_READ_INDY(ff(ACC |= val));
            break;
        case 0x15: // ORA, ZP,x
            OP_READ_ZP_IDX(XREG, ff(ACC |= val));
            break;
        case 0x16: // ASL, ZP,x
            OP_RMW_ZP_IDX(XREG, val = do_asl(val));
            break;
        case 0x19: // ORA, MEM,y
            OP_READ_ABS_IDX(YREG, ff(ACC |= val));
            break;
        case 0x1D: // ORA, MEM,x
            OP_READ_ABS_IDX(XREG, ff(ACC |= val));
            break;
        case 0x1E: // ASL, MEM,x
            OP_RMW_ABS_IDX(XREG, val = do_asl(val));
            break;
        case 0x2E: // ROL, abs
            OP_RMW_ABS(val = do_rol(val));
            break;
        case 0x31: // AND, (MEM),y
            OP_READ_INDY(ff(ACC &= val));
            break;
        case 0x35: // AND, ZP,x
            OP_READ_ZP_IDX(XREG, ff(ACC &= val));
            break;
        case 0x36: // ROL, ZP,x
            OP_RMW_ZP_IDX(XREG, val = do_rol(val));
            break;
        case 0x39: // AND, MEM,y
            OP_READ_ABS_IDX(YREG, ff(ACC &= val));
            break;
        case 0x3D: // AND, MEM,x
            OP_READ_ABS_IDX(XREG, ff(ACC &= val));
            break;
        case 0x3E: // ROL, MEM,x
            OP_RMW_ABS_IDX(XREG, val = do_rol(val));
            break;
        case 0x40: // RTI
            {
                cycle(); // end 2
                byte p = stack_pop();
                cycle(); // 3
                PFLAGS = (p & 0xCF) | PMASK(PUNUSED);
                byte lo = stack_pop();
                cycle(); // 4
                go_to(WORD(lo, HI(PC)));
                byte hi = stack_pop();
                cycle(); // 5
                go_to(WORD(lo, hi));
                (void) peek(STACK);
                cycle(); // 6
            }
            break;
        case 0x4E: // LSR, abs
            OP_RMW_ABS(val = do_lsr(val));
            break;
        case 0x51: // EOR, (MEM),y
            OP_READ_INDY(ff(ACC ^= val));
            break;
        case 0x55: // EOR, ZP,x
            OP_READ_ZP_IDX(XREG, ff(ACC ^= val));
            break;
        case 0x56: // LSR, ZP,x
            OP_RMW_ZP_IDX(XREG, val = do_lsr(val));
            break;
        case 0x59: // EOR, MEM,y
            OP_READ_ABS_IDX(YREG, ff(ACC ^= val));
            break;
        case 0x5D: // EOR, MEM,x
            OP_READ_ABS_IDX(XREG, ff(ACC ^= val));
            break;
        case 0x5E: // LSR, MEM,x
            OP_RMW_ABS_IDX(XREG, val = do_lsr(val));
            break;
        case 0x60: // RTS
            {
                word orig = PC;
                cycle(); // end 2
                byte lo = stack_pop();
                cycle(); // 3
                go_to(WORD(lo, HI(PC)));
                (void) stack_pop();
                cycle(); // 4
                byte hi = peek(STACK);
                word dest = WORD(lo, hi);
                go_to(dest);
                cycle(); // 5
                PC_ADV;
                cycle(); // 6
            }
            break;
        case 0x6C: // JMP ()
            {
                byte lo = immed;
                PC_ADV;
                cycle(); // 2
                byte hi = pc_get_adv();
                word addr = WORD(lo,hi);
                cycle(); // 3
                lo = peek(addr);
                cycle(); // 4
                if (machine_is_enhanced_iie()) {
                    hi = peek(addr+1);
                } else {
                    // 6502 page-crossing BUG!!
                    hi = peek(WORD(LO(addr+1),HI(addr)));
                }
                word dest = WORD(lo, hi);
                go_to(dest);
                cycle(); // 5
            }
            break;
        case 0x6E: // ROR, abs
            OP_RMW_ABS(val = do_ror(val));
            break;
        case 0x71: // ADC, (MEM),y
            OP_READ_INDY(do_adc(val));
            break;
        case 0x75: // ADC, ZP,x
            OP_READ_ZP_IDX(XREG, do_adc(val));
            break;
        case 0x76: // ROR, ZP,x
            OP_RMW_ZP_IDX(XREG, val = do_ror(val));
            break;
        case 0x79: // ADC MEM,y
            OP_READ_ABS_IDX(YREG, do_adc(val));
            break;
        case 0x7D: // ADC, MEM,x
            OP_READ_ABS_IDX(XREG, do_adc(val));
            break;
        case 0x7E: // ROR, MEM,x
            OP_RMW_ABS_IDX(XREG, val = do_ror(val));
            break;
        case 0x81: // STA, (MEM,x)
            OP_WRITE_INDX(ACC);
            break;
        case 0x84: // STY, ZP
            OP_WRITE_ZP(YREG);
            break;
        case 0x85: // STA, ZP
            OP_WRITE_ZP(ACC);
            break;
        case 0x86: // STX, ZP
            OP_WRITE_ZP(XREG);
            break;
        case 0x91: // STA, (MEM),y
            OP_WRITE_INDY(ACC);
            break;
        case 0x94: // STY, ZP,x
            OP_WRITE_ZP_IDX(XREG, YREG);
            break;
        case 0x95: // STA, ZP,x
            OP_WRITE_ZP_IDX(XREG, ACC);
            break;
        case 0x96: // STX, ZP,y
            OP_WRITE_ZP_IDX(YREG, XREG);
            break;
        case 0x99: // STA, MEM,y
            OP_WRITE_ABS_IDX(YREG, ACC);
            break;
        case 0x9D: // STA, MEM,x
            OP_WRITE_ABS_IDX(XREG, ACC);
            break;
        case 0xB1: // LDA, (MEM),y
            OP_READ_INDY(ff(ACC = val));
            break;
        case 0xB4: // LDY, ZP,x
            OP_READ_ZP_IDX(XREG, ff(YREG = val));
            break;
        case 0xB5: // LDA, ZP,x
            OP_READ_ZP_IDX(XREG, ff(ACC = val));
            break;
        case 0xB6: // LDX, ZP,y
            OP_READ_ZP_IDX(YREG, ff(XREG = val));
            break;
        case 0xB9: // LDA, MEM,y
            OP_READ_ABS_IDX(YREG, ff(ACC = val));
            break;
        case 0xBC: // LDY MEM,x
            OP_READ_ABS_IDX(XREG, ff(YREG = val));
            break;
        case 0xBD: // LDA MEM,x
            OP_READ_ABS_IDX(XREG, ff(ACC = val));
            break;
        case 0xBE: // LDX MEM,y
            OP_READ_ABS_IDX(YREG, ff(XREG = val));
            break;
        case 0xCE: // DEC, abs.
            OP_RMW_ABS(ff(--val));
            break;
        case 0xD1: // CMP, (MEM),y
            OP_READ_INDY(do_cmp(ACC, val));
            break;
        case 0xD5: // CMP, ZP,x
            OP_READ_ZP_IDX(XREG, do_cmp(ACC, val));
            break;
        case 0xD6: // DEC, ZP,x
            OP_RMW_ZP_IDX(XREG, ff(--val));
            break;
        case 0xD9: // CMP, MEM,y
            OP_READ_ABS_IDX(YREG, do_cmp(ACC, val));
            break;
        case 0xDD: // CMP, MEM,x
            OP_READ_ABS_IDX(XREG, do_cmp(ACC, val));
            break;
        case 0xDE: // DEC, MEM,x
            OP_RMW_ABS_IDX(XREG, ff(--val));
            break;
        case 0xEE: // INC, abs.
            OP_RMW_ABS(ff(++val));
            break;
        case 0xF1: // SBC, (MEM),y
            OP_READ_INDY(do_sbc(val));
            break;
        case 0xF5: // SBC, ZP,x
            OP_READ_ZP_IDX(XREG, do_sbc(val));
            break;
        case 0xF6: // INC, ZP,x
            OP_RMW_ZP_IDX(XREG, ff(++val));
            break;
        case 0xF9: // SBC, MEM,y
            OP_READ_ABS_IDX(YREG, do_sbc(val));
            break;
        case 0xFD: // SBC, MEM,x
            OP_READ_ABS_IDX(XREG, do_sbc(val));
            break;
        case 0xFE: // INC, MEM,x
            OP_RMW_ABS_IDX(XREG, ff(++val));
            break;
        case 0x00: // BRK
            handle_brk_or_illegal(op);
            break;
        default:
            return false; // NOT handled.
    }
    return true; // handled.
}

--]==]
end -- do (for local scoping)
